---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="text-center mb-12">
      <h1 class="section-heading">How BowlSmart works</h1>
      <p class="text-xl text-slate mt-4">Three simple steps to smarter bowling.</p>
    </div>

    <div class="space-y-12">
      <div class="flex gap-8">
        <div class="w-12 h-12 flex-shrink-0 rounded-full bg-neon-green text-navy flex items-center justify-center text-2xl font-bold">1</div>
        <div>
          <h3 class="text-2xl font-semibold mb-2">Create your profile</h3>
          <p class="text-slate">Sign up as a bowler, coach, or parent. Coaches can instantly generate invite codes or QR codes for their team.</p>
        </div>
      </div>
      
      <div class="flex gap-8">
        <div class="w-12 h-12 flex-shrink-0 rounded-full bg-neon-orange text-white flex items-center justify-center text-2xl font-bold">2</div>
        <div>
          <h3 class="text-2xl font-semibold mb-2">Build &amp; log together</h3>
          <p class="text-slate">Bowlers log sessions and receive smart recommendations. Coaches manage rosters, send messages, and track team performance. Parents receive updates automatically.</p>
        </div>
      </div>
      
      <div class="flex gap-8">
        <div class="w-12 h-12 flex-shrink-0 rounded-full bg-neon-green text-navy flex items-center justify-center text-2xl font-bold">3</div>
        <div>
          <h3 class="text-2xl font-semibold mb-2">Stay connected anywhere</h3>
          <p class="text-slate">Works on mobile and web. Data syncs to the cloud when online. Local mode keeps everything working offline-first.</p>
        </div>
      </div>
    </div>

    <div class="mt-16 p-8 bg-navy-light rounded-2xl text-center">
      <p class="text-lg">The same friendly coach-like experience you know from the app — now on the web for the whole team.</p>
    </div>
  </div>
</Layout>