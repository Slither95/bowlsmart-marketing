---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="section-heading">Resources &amp; Guides</h1>
    <p class="text-xl text-slate mt-3">Tips, ball guides, and best practices from the BowlSmart team.</p>

    <div class="mt-12 space-y-6">
      <div class="card">
        <div class="text-sm text-neon-green font-medium">GUIDE</div>
        <h3 class="text-2xl font-semibold mt-1">Choosing Your First Arsenal Ball</h3>
        <p class="text-slate mt-2">A beginner-friendly breakdown of coverstock, core, and when to choose each ball type.</p>
        <a href="/blog/choosing-your-first-ball" class="text-neon-orange mt-3 inline-block">Read the guide →</a>
      </div>
      
      <div class="card">
        <div class="text-sm text-neon-green font-medium">ARTICLE</div>
        <h3 class="text-2xl font-semibold mt-1">How High School Teams Are Using Data to Win More Matches</h3>
        <p class="text-slate mt-2">Real stories from coaches who turned averages and ball logs into a competitive edge.</p>
        <a href="#" class="text-neon-orange mt-3 inline-block">Read more →</a>
      </div>
    </div>

    <div class="mt-10 text-sm text-slate">More resources coming soon. Have a topic suggestion? <a href="/get-started" class="text-neon-green">Let us know</a>.</div>
  </div>
</Layout>