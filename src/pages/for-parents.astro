---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="section-heading">Peace of mind for parents</h1>
    <p class="mt-4 text-xl text-slate">Read-only access so you can follow your athlete's progress without managing anything yourself.</p>

    <div class="mt-12 grid md:grid-cols-3 gap-6">
      <div class="card">
        <div class="text-3xl mb-4">📬</div>
        <div class="font-semibold mb-1">Real-time notifications</div>
        <div class="text-sm text-slate">Get push alerts when new messages or schedule updates arrive.</div>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">📊</div>
        <div class="font-semibold mb-1">View stats &amp; arsenal</div>
        <div class="text-sm text-slate">See current averages, recent sessions, and recommended balls.</div>
      </div>
      <div class="card">
        <div class="text-3xl mb-4">🔒</div>
        <div class="font-semibold mb-1">No extra logins</div>
        <div class="text-sm text-slate">Linked via coach invite. Simple, secure, and always up to date.</div>
      </div>
    </div>
  </div>
</Layout>